<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="rename-table-and-drop-column" author="PRASI">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="last_updated"/>
                <not><tableExists tableName="user_selected_items"/></not>
            </and>
        </preConditions>
        <renameTable oldTableName="last_updated" newTableName="user_selected_items"/>
        <dropColumn tableName="user_selected_items" columnName="last_updated"/>
    </changeSet>

</databaseChangeLog>
