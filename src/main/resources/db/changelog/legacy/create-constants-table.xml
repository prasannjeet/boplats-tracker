<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-constants-table" author="PRASI">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="constants"/></not>
        </preConditions>
        <createTable tableName="constants">
            <column name="id" type="int">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="last_database_updated" type="timestamp">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="insert-initial-constants-row" author="PRASI">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM constants</sqlCheck>
        </preConditions>
        <insert tableName="constants">
            <column name="id" valueNumeric="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>
