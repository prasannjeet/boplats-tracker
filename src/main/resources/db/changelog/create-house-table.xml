<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-house-table" author="vaxjobostader-ai-assistant">
        <createTable tableName="house">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="local_id" type="VARCHAR(255)"/>
            <column name="address" type="VARCHAR(500)"/>
            <column name="description" type="TEXT"/>
            <column name="rent" type="DOUBLE"/>
            <column name="area" type="DOUBLE"/>
            <column name="rooms" type="INT"/>
            <column name="available_from" type="DATE"/>
            <column name="application_deadline" type="DATETIME"/>
            <column name="image_url" type="VARCHAR(1000)"/>
            <column name="end_date" type="DATE"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
