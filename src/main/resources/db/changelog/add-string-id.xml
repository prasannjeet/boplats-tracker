<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="update-id-to-string" author="PRASI">
        <!-- Alter column data type -->
        <modifyDataType tableName="last_updated" columnName="id" newDataType="VARCHAR(255)"/>

        <!-- Update the existing row's ID -->
        <update tableName="last_updated">
            <column name="id" value="Prasannjeet"/>
            <where>id = 1</where>
        </update>
    </changeSet>

</databaseChangeLog>
